{
  "name": "asr-local-electron",
  "productName": "ASR Local",
  "description": "Local-first speech-to-text and workflow desktop application",
  "author": "ASR Local",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:compile && concurrently -k \"vite --host 127.0.0.1 --port 1420\" \"wait-on http://127.0.0.1:1420 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:1420 electron .\"",
    "electron:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/dev/start_electron_debug.ps1 -DataProfile real",
    "electron:debug:isolated": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/dev/start_electron_debug.ps1 -DataProfile isolated",
    "electron:package:fast": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/dev/package_electron_fast.ps1",
    "workflow:watch": "runtime\\python\\python.exe ..\\..\\scripts\\dev\\watch_workflow.py",
    "workflow:watch:once": "runtime\\python\\python.exe ..\\..\\scripts\\dev\\watch_workflow.py --once",
    "electron:build": "npm run build && npm run electron:compile",
    "runtime:build": "powershell -ExecutionPolicy Bypass -File ../../scripts/build/build_python_runtime.ps1",
    "electron:package": "npm run runtime:build && npm run electron:build && electron-builder --win dir",
    "electron:dist": "npm run runtime:build && npm run electron:build && electron-builder --win nsis",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/language": "^6.11.3",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@lucide/vue": "^1.17.0",
    "dompurify": "^3.4.11",
    "markdown-it": "^14.1.0",
    "pinia": "^2.3.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  },
  "build": {
    "appId": "local.asr.desktop",
    "productName": "ASR Local",
    "asar": false,
    "directories": {
      "output": "release-electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../worker-python",
        "to": "runtime-root/apps/worker-python",
        "filter": [
          "app/**/*",
          "scripts/**/*",
          "pyproject.toml",
          "README.md"
        ]
      },
      {
        "from": "../../config/models.toml",
        "to": "runtime-root/config/models.toml"
      },
      {
        "from": "../../config/summary_templates.toml",
        "to": "runtime-root/config/summary_templates.toml"
      },
      {
        "from": "runtime/python",
        "to": "runtime-root/runtime/python"
      },
      {
        "from": "runtime/qwen-python",
        "to": "runtime-root/runtime/qwen-python"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "electron/resources/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
