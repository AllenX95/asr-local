{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ASR Local Tauri",
  "version": "0.1.0",
  "identifier": "local.asr.desktop.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "本地 ASR 听记助手",
        "width": 1360,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
